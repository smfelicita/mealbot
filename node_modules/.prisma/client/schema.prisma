// This is your Prisma schema file

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id               String   @id @default(cuid())
  email            String?  @unique
  passwordHash     String?
  name             String?
  telegramId       String?  @unique
  telegramUsername String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  fridge      FridgeItem[]
  chatHistory ChatMessage[]
  preferences UserPreferences?

  @@map("users")
}

model UserPreferences {
  id                  String   @id @default(cuid())
  userId              String   @unique
  user                User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  dietaryTags         String[] // вегетарианское, без глютена и т.д.
  dislikedIngredients String[]
  preferredMealTimes  String[] // breakfast, lunch, dinner
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@map("user_preferences")
}

model Ingredient {
  id       String  @id @default(cuid())
  name     String  @unique
  nameRu   String  @unique
  category String // dairy, meat, vegetable, grain, spice, etc.
  emoji    String?

  dishes DishIngredient[]
  fridge FridgeItem[]

  @@map("ingredients")
}

model FridgeItem {
  id           String     @id @default(cuid())
  userId       String
  user         User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  ingredientId String
  ingredient   Ingredient @relation(fields: [ingredientId], references: [id])
  addedAt      DateTime   @default(now())
  expiresAt    DateTime?

  @@unique([userId, ingredientId])
  @@map("fridge_items")
}

model Dish {
  id          String       @id @default(cuid())
  name        String
  nameRu      String
  description String?
  category    MealCategory
  mealTime    String[] // breakfast, lunch, dinner, snack
  tags        String[] // вегетарианское, быстро, суп и т.д.
  cookTime    Int? // минуты
  difficulty  String? // easy, medium, hard
  calories    Int?
  imageUrl    String?
  recipe      String? // markdown текст рецепта

  ingredients DishIngredient[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("dishes")
}

model DishIngredient {
  id           String     @id @default(cuid())
  dishId       String
  dish         Dish       @relation(fields: [dishId], references: [id], onDelete: Cascade)
  ingredientId String
  ingredient   Ingredient @relation(fields: [ingredientId], references: [id])
  amount       String? // "2 шт", "200г" и т.д.
  optional     Boolean    @default(false)

  @@unique([dishId, ingredientId])
  @@map("dish_ingredients")
}

model ChatMessage {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  role      String // user | assistant
  content   String
  platform  String // web | telegram
  createdAt DateTime @default(now())

  @@map("chat_messages")
}

enum MealCategory {
  BREAKFAST
  LUNCH
  DINNER
  SNACK
  SOUP
  SALAD
  DESSERT
  DRINK
}
